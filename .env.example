# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Auto-added by Vercel when you create a Blob store (Storage tab in dashboard)
# For local dev: copy the token from Vercel dashboard → Storage → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Resend ────────────────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Sender address ────────────────────────────────────────────────────────────
# During development you can use:  PostCardiB <onboarding@resend.dev>
# For production, set your verified domain address:
#   PostCardiB <postcards@yourdomain.com>
FROM_EMAIL=PostCardiB <onboarding@resend.dev>
